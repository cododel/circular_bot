BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id

# Optional: comma-separated list of allowed user IDs (whitelist)
# If set, bot will only respond to these users
ALLOW_USER_IDS=your_telegram_id

# Video Processing Settings (all optional, have defaults)

# Processing timeout in seconds (default: 480 = 8 minutes)
PROCESSING_TIMEOUT=480

# Progress update interval in seconds (default: 3)
# Note: This is a temporary stub, will be improved
PROGRESS_UPDATE_INTERVAL=3

# Background zoom scale (default: 1.08)
ZOOM_SCALE=1.08

# Circle size as ratio of video size (default: 0.82)
CIRCLE_SIZE_RATIO=0.82

# Background blur amount (default: 40)
BACKGROUND_BLUR=40

# Font size as ratio of video height (default: 0.035)
TEXT_FONT_SIZE_RATIO=0.035

# Text padding from circle as ratio of video height (default: 0.02)
TEXT_PADDING_RATIO=0.02

# Background brightness adjustment (default: -0.15)
BRIGHTNESS_ADJUST=-0.15

# Background contrast adjustment (default: 1.1)
CONTRAST_ADJUST=1.1

# Performance settings
# FFmpeg threads: 0 = auto (use all CPU cores), or specify number (e.g., 4)
FFMPEG_THREADS=0
